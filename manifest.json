{
    "manifest_version": 2,
    "name": "DLS Theme",
    "description": "A simple chrome extension used to Inject CSS codes into DLS to change it's appearance",
    "version": "1.0",
    "author": "Iyxan23",
    "permissions": [
        "tabs",
        "<all_urls>",
        "storage",
        "http://*/*",
        "https://*/*"
    ],
    "icons": { 
        "16": "dlstheme-16.png",
        "48": "dlstheme-48.png",
        "128": "dlstheme-128.png" 
    },
    "content_scripts": [ 
        { 
            "all_frames": false, 
            "js": ["js/glsmp.js"], 
            "matches": ["*://www.e.smpialazhar21.sch.id/*"],
            "run_at": "document_end" 
        } 
    ],
    "web_accessible_resources": [
        "js/glsmp.js",
        "css/glsmp.min.css"
    ]
}
